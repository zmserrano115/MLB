APP_ENV=development
LOG_LEVEL=INFO
APP_TIMEZONE=America/Denver
DATABASE_URL=postgresql+psycopg://all_rise:all_rise@postgres:5432/all_rise
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=30
CACHE_NEGATIVE_TTL_SECONDS=5
CACHE_LEASE_TTL_MS=5000
REDIS_TIMEOUT_MS=250
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MLB_API_BASE_URL=https://statsapi.mlb.com
WEATHER_API_BASE_URL=https://api.open-meteo.com
GCS_BUCKET=
ARTIFACT_STORE=local
ARTIFACT_LOCAL_ROOT=/var/lib/all-rise/artifacts
JOB_SOURCE_OWNERSHIP=shadow
JOB_ACTIVE_TASKS=
JOB_STALE_AFTER_SECONDS=300
JOB_MAX_ATTEMPTS=5
API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000
BUILD_SHA=development
SCHEMA_REVISION=0003_durable_job_execution
MAX_REQUEST_BODY_BYTES=1048576
SLOW_REQUEST_MS=500
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
